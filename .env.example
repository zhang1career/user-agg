APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=redis
CACHE_PREFIX=fio

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# 对象存储 (S3 兼容，本地 OSS 服务，接口见 api_oss.json)
# 必须填写，否则 AWS SDK 会尝试请求 EC2 元数据服务导致超时；本地 OSS 可用占位值
# Docker 内访问时请将 localhost 改为服务名（如 oss 或 app_oss）
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=user-agg
AWS_ENDPOINT=http://localhost:18041/api/oss
AWS_URL=http://localhost:18041/api/oss
AWS_USE_PATH_STYLE_ENDPOINT=true

# CDN（CloudFront 兼容，如 serv-fd app_cdn）
# 关闭时使用直连 OSS URL（见 AWS_URL）
OSS_CDN_ENABLED=true
# 下载 URL 会返回给客户端（浏览器），必须用客户端可访问的主机！
# serv-fd:8000 仅 Docker 内可解析，宿主机/浏览器需用 localhost:18041
# 若 cdn_url 已写入错误主机，运行: php artisan media:fix-cdn-url
# 方式一：直接设置内容分发根 URL（将 E1234ABCD 换成你的 distribution_id）
# AWS_CLOUDFRONT_DOMAIN=http://localhost:18041/api/cdn/2020-05-31/d/E1234ABCD
# 方式二：由下方两项推导
CDN_API_BASE_URL=http://localhost:18041/api/cdn/2020-05-31
CDN_DISTRIBUTION_ID=

MEDIA_RAW_PREFIX=media/raw
MEDIA_TRANSCODED_PREFIX=media/transcoded
# 需要 ffmpeg 转码的 MIME 类型代码，逗号分隔（1=mp4, 2=mov, 3=webm, 5=jpeg, 6=png 等，见 MediaFile::MIME_*）
MEDIA_TRANSCODABLE_MIMES=1,2,3
# 非转码类型的默认行为：passthrough=原样输出，fail=标记失败
MEDIA_DEFAULT_ACTION=passthrough
FFMPEG_BINARY=ffmpeg
FFMPEG_TIMEOUT=600
FFMPEG_PRESET=veryfast
FFMPEG_CRF=23

# API Gateway Configuration
API_GATEWAY_BASE_URL=http://nginx:8010
API_GATEWAY_ACCOUNT_RULE_BROKER_USER=rule.backend
API_GATEWAY_ACCOUNT_RULE_BROKER_PASS=12345678
# 当 base_url 含服务发现占位符 `://{{service_key}}` 时从 Redis 解析；否则忽略下列项
API_GATEWAY_SD_DB_CONN=default
API_GATEWAY_SD_KEY_PREFIX=reg:serv:
API_GATEWAY_SD_MEMO_TTL=60

USER_CENTER_TIMEOUT_SECONDS=3
USER_CENTER_UNAUTHORIZED_CODE=40101

USER_BIZ_ACCOUNT_PROFILE_ENABLED=true
USER_BIZ_ACCOUNT_PROFILE_BASE_URL=
USER_BIZ_ACCOUNT_PROFILE_ENDPOINT=/api/user/profile
USER_BIZ_ACCOUNT_PROFILE_TIMEOUT_SECONDS=3

USER_BIZ_MEMBERSHIP_TIER_ENABLED=false
USER_BIZ_MEMBERSHIP_TIER_BASE_URL=
USER_BIZ_MEMBERSHIP_TIER_ENDPOINT=/api/user/membership
USER_BIZ_MEMBERSHIP_TIER_TIMEOUT_SECONDS=3

USER_AGG_EXECUTION_MODE=serial
USER_AGG_DEGRADE_STRATEGY=mask_null
USER_AGG_DEGRADE_MASK_ERROR_MESSAGE="Service temporarily unavailable."
USER_AGG_PARTIAL_FAILURE_CODE=20601
USER_AGG_PARTIAL_FAILURE_MESSAGE="Partially failed, degraded by aggregator."

VITE_APP_NAME="${APP_NAME}"
