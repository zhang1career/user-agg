# 分层环境（与 bet-agg 一致）：仅当 APP_ENV 为 dev / test / prod 时叠加加载根目录 `.env.{APP_ENV}`。
# 本地 `APP_ENV=local`、PHPUnit `testing` 不会加载叠加文件。
APP_NAME=user-agg
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=user_agg
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=array

# 当 API_GATEWAY_BASE_URL 含 `://{{service_key}}` 服务发现占位时，需配置 Redis（见 config/database.php 的 redis 段）。
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379

# S3 兼容（上传）；密钥与 endpoint 必填以免 SDK 访问 EC2 元数据超时。
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=user-agg
AWS_ENDPOINT=
AWS_URL=
AWS_USE_PATH_STYLE_ENDPOINT=true

# CDN：关闭则使用 S3/OSS 直链（见 config/media.php、config/services.php）
OSS_CDN_ENABLED=true
AWS_CLOUDFRONT_DOMAIN=
# CDN_API_BASE_URL=
# CDN_DISTRIBUTION_ID=

MEDIA_RAW_PREFIX=media/raw
MEDIA_TRANSCODED_PREFIX=media/transcoded

# 用户中心网关（与下游路径默认值见 config/user_agg.php）
API_GATEWAY_BASE_URL=http://nginx:8010
API_GATEWAY_SD_DB_CONN=default
API_GATEWAY_SD_KEY_PREFIX=reg:serv:
API_GATEWAY_SD_MEMO_TTL=60
USER_CENTER_TIMEOUT_SECONDS=3
USER_CENTER_UNAUTHORIZED_CODE=40101

USER_BIZ_ACCOUNT_PROFILE_ENABLED=true
USER_BIZ_ACCOUNT_PROFILE_BASE_URL=
USER_BIZ_MEMBERSHIP_TIER_ENABLED=false
USER_BIZ_MEMBERSHIP_TIER_BASE_URL=

USER_AGG_EXECUTION_MODE=serial
USER_AGG_DEGRADE_STRATEGY=mask_null
USER_AGG_PARTIAL_FAILURE_CODE=20601
USER_AGG_PARTIAL_FAILURE_MESSAGE="Partially failed, degraded by aggregator."

VITE_APP_NAME="${APP_NAME}"
